---
import { Picture } from "astro:assets";
import kirasuiGardens from "../../img/KirasuiGardens.png";
---

<div
  id="join"
  class="relative w-full mt-15 ml-0 opacity-0 translate-x-31.25 slide-right transition-all duration-800 ease-out translate-y-6.25 fade-in"
>
  <Picture
    src={kirasuiGardens}
    formats={["avif", "webp", "png"]}
    layout="full-width"
    alt="Kirasui Gardens"
    class="w-full h-auto"
    loading="eager"
    fetchpriority="high"
  />
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-archivo text-center bg-black opacity-75 min-[600px]:px-6.25 min-[600px]:py-8.75 px-1 py-2 rounded-xl shadow-[0_5px_15px_rgba(0,0,0,1)] max-[600px]:w-full"
  >
    <h2 class="min-[600px]:text-[45px] text-[25px] font-bold">Join today!</h2>
    <p class="min-[600px]:text-[30px] text-[15px] text-blue-500">
      <a class="underline decoration-solid" href="https://discord.gg/NawCaMFnjr"
        >Discord Link</a>
    </p>
    <h2 class="min-[600px]:text-[45px] text-[25px] font-bold">
      Want to see more amazing photos?
    </h2>
    <p class="min-[600px]:text-[30px] text-[15px]">
      Join the Discord to see more!
    </p>
  </div>
</div>

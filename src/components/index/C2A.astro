---
import { Picture } from "astro:assets";
import kirasuiGardens from '../../img/KirasuiGardens.png'
---

<div id="join" class="relative w-full mt-15 ml-0 opacity-0 translate-x-31.25 slide-right transition-all duration-800 ease-out translate-y-6.25 fade-in">
  <Picture
    src={kirasuiGardens}
    formats={["avif", "webp", "png"]}
    layout="full-width"
    alt="Kirasui Gardens"
    class="w-full h-auto"
    loading="lazy"
  />
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-(family-name:--font-archivo) text-center bg-black opacity-75 px-6.25 py-8.75 rounded-xl shadow-[0_5px_15px_rgba(0,0,0,1)]">
    <h2 class="text-[45px]">Join today!</h2>
    <p class="text-[30px]"><a href="https://discord.gg/NawCaMFnjr">Discord Link</a></p>
    <h2 class="text-[45px]">Want to see more amazing photos?</h2>
    <p class="text-[30px]">Join the Discord to see more!</p>
  </div>
</div>
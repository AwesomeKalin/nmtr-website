---
const props = Astro.props;
---

<div
    class="text-center pt-20 pr-5 pb-10 pl-5 opacity-0 translate-y-6.25 transition-all duration-800 ease-out fade-in delay-150"
>
    <h1
        class="font-bold text-[60px] font-archivo mb-3.75 opacity-0 translate-y-6.25 transition-all duration-800 ease-out fade-in delay-300"
    >
        {props.title}
    </h1>
    <p
        class="text-[22px] max-w-200 mx-auto my-0 opacity-0 translate-y-6.25 transition-all duration-800 ease-out fade-in delay-450"
    >
        {props.description}
    </p>
</div>

---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { Font } from 'astro:assets';

const props = Astro.props;
---
	
<html lang="en" class="bg-[#0a0a0a]">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>NovaMTR - {props.title}</title>
	</head>
	<body class="text-white font-(family-name:--font-poppins)">
		<Font cssVariable="--font-archivo" preload />
		<Font cssVariable="--font-poppins" preload />
		<Font cssVariable="--font-atkinson" preload />
        <Header />
		<slot />
		<Footer />
	</body>
</html>

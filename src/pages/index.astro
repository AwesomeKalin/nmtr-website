---
import Layout from "../layouts/Layout.astro";
import Banner from "../components/Banner.astro";
import ImageWithText from "../components/ImageWithText.astro";
import TextWithIframe from "../components/TextWithIframe.astro";

import morganBay from "../img/morganbay.png";
import hoWingKokPier from "../img/howingkokpier.png";
import concurrent from "../img/concurrent.png";
import milbourne from "../img/milbourne.png";
---

<Layout title="Home">
    <Banner />
    <div
        class="m-auto text-left text-[1.75vw] @min-[1001px]:text-[40px] @min-[1401px]:text-[30px] w-4/5 px-[4vw] bg-fuchsia-50 border-5 border-solid border-fuchsia-300 transition duration-300 font-extrabold"
    >
        <h1
            class="font-[Trebuchet MS, serif] text-[#ff77ff] [font-variant:small-caps] block text-[3em] my-[0.67em] mx-0 font-bold [unicode-bidi:isolate]"
        >
            Your journey begins here
        </h1>

        <ImageWithText
            title="Introduction"
            img={morganBay}
            alt="Morgan Bay Station, designed and built by TribalKing2025"
            >Hi, welcome to NovaMTR! We're a small little server based on the
            Minecraft Transit Railway mod! Here you can meet new people and
            freely express yourselves, and have fun playing on the server!
            (Probably)</ImageWithText
        >

        <ImageWithText
            title="Our network"
            img={hoWingKokPier}
            alt="Ho Wing Kok Pier Station, built by Curt"
            >Starting since July of 2025, we've been rapidly expanding since!
            The amount of railways and transports in our MTR server is big
            enough to serve the best cities in the world, and in some cases
            bigger than other MTR servers!</ImageWithText
        >

        <ImageWithText
            title="Our community"
            img={concurrent}
            alt="Screenshot taken, celebrating the 11 concurrent players mark"
            >Our LGBTQ+ friendly community allows people all across the globe to
            talk to each other safely! Here you can have discussions in forums,
            showcase your Minecraft builds and many more!</ImageWithText
        >

        <ImageWithText
            title="Becoming a builder"
            img={milbourne}
            alt="Screenshot taken along the Milbourne Line, built by Curt"
            >We'd be glad for you to become part of our buider team! You can
            apply for a builder application, and if we approve it, showcase your
            skills in a build test, taken place within our Minecraft server!</ImageWithText
        >

        <TextWithIframe
            title="Our dynamic square map"
            iframeSrc="http://squaremap.novamtr.org"
            iframeTitle="Squaremap"
            link="http://squaremap.novamtr.org"
            extraBreaks={1}
            >Our dynamic square map allows you to view the whole NMTR world,
            including markers where stations are! This could be very helpful for
            planning where to build your next transport line.</TextWithIframe
        >

        <TextWithIframe
            title="Our dynamic system map"
            iframeSrc="http://system-map.novamtr.org"
            iframeTitle="System Map"
            link="http://system-map.novamtr.org"
            extraBreaks={3}
            >Our dynamic system map allows you to view the whole NMTR network in
            full, while keeping the interface clean and readable!</TextWithIframe
        >

        <iframe
            class="float-right text-center border-5 border-solid border-fuchsia-300 max-w-140 max-h-78.75 w-full"
            width="560"
            height="315"
            referrerpolicy="strict-origin-when-cross-origin"
            src="https://www.youtube-nocookie.com/embed/6ijTozc-Mtc"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            title="YouTube Channel"
            loading="lazy"></iframe>

        <h2
            class="font-[Trebuchet MS, serif] text-[#7777ff] text-4xl my-[0.83em] mx-0
        font-bold [unicode-bidi:isolate]"
        >
            Our YouTube channel
        </h2>
        <p
            class="font-[Arial, sans-serif] text-[#777777] block my-[1em] mx-0 [unicode-bidi:isolate]"
        >
            In case you don't know, we have a YouTube channel! Here we post
            timelapses, cab rides and many more.
        </p>
        <br /><br /><br />

        <a
            class="text-black flex justify-center"
            href="https://www.youtube.com/@NovaMTR"
            ><div
                class="bg-[#ffbbff] p-5 w-75 text-center transition duration-300 mb-5 @max-[1000px]:w-4/5 @max-[1000px]:m-auto hover:bg-[#eeaaee]"
            >
                Check it out!
            </div></a
        >
    </div>
</Layout>
